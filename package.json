{
  "name": "dbg",
  "version": "0.1.0",
  "description": "Editor-agnostic DAP debugging frontend (Electron POC)",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "bin": {
    "dbg": "./bin/dbg.js"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "dev:fixture": "electron-vite dev -- run --adapter lldb-dap --program fixtures/loop-demo/target/debug/loop-demo --source fixtures/loop-demo/src/main.rs",
    "build": "electron-vite build",
    "typecheck": "tsc -p tsconfig.node.json && tsc -p tsconfig.web.json",
    "smoke": "tsx scripts/smoke-test.ts",
    "smoke:session": "tsx scripts/session-smoke-test.ts"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vscode/debugprotocol": "^1.68.0",
    "electron": "^43.1.1",
    "electron-vite": "^5.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shiki": "^4.3.1",
    "tsx": "^4.23.1",
    "typescript": "^5.7.3",
    "vite": "^7.3.6",
    "zustand": "^5.0.14"
  }
}
